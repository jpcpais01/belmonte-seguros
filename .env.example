# Email delivery for the contact form (optional, recommended for production).
# The form works without these (it validates + logs), but to actually
# receive emails, sign up at https://resend.com, then set:

# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# CONTACT_TO_EMAIL=geral@belmonte-seguros.pt

# After setting these, enable the delivery block in app/actions.ts
# (and run: npm install resend).
